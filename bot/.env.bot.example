# Telegram Bot Configuration
# Copy this file to .env.bot.secret and fill in real values

# Telegram Bot token (get from @BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# LMS API Configuration
LMS_API_BASE_URL=http://localhost:42002
LMS_API_KEY=my-secret-api-key

# LLM API Configuration (Qwen Code proxy)
LLM_API_BASE_URL=http://localhost:42005/v1
LLM_API_KEY=my-qwen-api-key
LLM_API_MODEL=coder-model
